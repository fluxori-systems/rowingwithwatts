---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import siteConfig from '@/config/site.config';
---
<PageLayout
  title={`About — ${siteConfig.name}`}
  description="Rowing With Watts is a data-driven indoor rowing blog founded by Tarquin Stapa. We publish honest guides, personal case studies, and watt-based training insights to help you row smarter."
>
  <!-- Hero -->
  <Hero layout="centered" size="sm" waterAnimation>
    <Badge slot="badge" variant="brand" pill class="!bg-[rgba(40,180,160,0.2)] !text-[#5ce0d0] !border-[rgba(80,200,180,0.3)]">
      <Icon name="user" size="sm" />
      About Us
    </Badge>
    <h1 slot="title">
      About Rowing<br />
      <span class="rww-hero-accent">With Watts</span>
    </h1>
    <p slot="description">
      Your go-to source for indoor rowing training, watt-based performance data, and honest case studies. We help rowers train smarter through evidence-backed content.
    </p>
  </Hero>

  <!-- Mission -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="flex flex-col gap-4" data-reveal>
          <div class="flex flex-col gap-6">
            <Badge variant="brand" pill class="self-start">Our Mission</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Empowering a million lives<br />
              <span class="text-brand-500">through rowing</span>
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed">
            Our big dream? To guide a million people towards a healthier and happier life with indoor rowing. Think of us as your knowledgeable friend in the rowing world — here to make your fitness journey as effective and enjoyable as possible.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            We believe watts don't lie. Every guide, review, and case study on this site is built on real training data — not speculation, not marketing copy. Just results from a rower who shows up every day and logs the numbers.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4 content-start" data-reveal data-reveal-delay="1">
          <Card hover class="text-center flex flex-col items-center gap-3 py-6">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="check-circle" size="md" />
            </div>
            <h3 class="text-sm font-semibold text-foreground">Evidence-Based</h3>
            <p class="text-xs text-foreground-muted leading-relaxed">Every claim backed by peer-reviewed research or personal data</p>
          </Card>
          <Card hover class="text-center flex flex-col items-center gap-3 py-6">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="zap" size="md" />
            </div>
            <h3 class="text-sm font-semibold text-foreground">Watt-Based</h3>
            <p class="text-xs text-foreground-muted leading-relaxed">Real power output data — not pace estimates or vague effort levels</p>
          </Card>
          <Card hover class="text-center flex flex-col items-center gap-3 py-6">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="trending-up" size="md" />
            </div>
            <h3 class="text-sm font-semibold text-foreground">Case Studies</h3>
            <p class="text-xs text-foreground-muted leading-relaxed">Month-long personal experiments with before/after data</p>
          </Card>
          <Card hover class="text-center flex flex-col items-center gap-3 py-6">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
              <Icon name="shield" size="md" />
            </div>
            <h3 class="text-sm font-semibold text-foreground">Unbiased</h3>
            <p class="text-xs text-foreground-muted leading-relaxed">Merit-based recommendations, never influenced by commission potential</p>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col items-center gap-4 text-center mb-12" data-reveal>
        <Badge variant="brand" pill>Our Story</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Born from passion and necessity
        </h2>
      </div>
      <div class="grid gap-8 md:grid-cols-3" data-reveal data-reveal-delay="1">
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="heart" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-bold uppercase tracking-widest text-foreground-muted mb-1">2023 — Founded</p>
              <h3 class="text-base font-semibold text-foreground">A CrossFit Detour</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Sidelined by a knee injury from CrossFit, I discovered indoor rowing. It was a revelation — a perfect blend of low-impact exercise and intense physical challenge.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="search" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-bold uppercase tracking-widest text-foreground-muted mb-1">The Gap</p>
              <h3 class="text-base font-semibold text-foreground">Missing Research</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                There was a significant gap in the online space for in-depth, research-backed information about the effects of indoor rowing on the body. That sparked an idea.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="rocket" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-xs font-bold uppercase tracking-widest text-foreground-muted mb-1">The Mission</p>
              <h3 class="text-base font-semibold text-foreground">Filling the Void</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Rowing With Watts was born to provide a platform where fitness and scientific research intersect — offering insights into the transformative power of rowing.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- What We Cover -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col items-center gap-4 text-center mb-12" data-reveal>
        <Badge variant="brand" pill>What We Cover</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Topics that matter to rowers
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          From beginner fundamentals to advanced performance analysis — we cover it all with the same commitment to honest, data-backed content.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal data-reveal-delay="1">
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="bar-chart-2" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Data-Driven Guides</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Watt-based training zones, stroke rate analysis, and performance benchmarks backed by real data.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="star" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Machine Reviews</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Unbiased reviews of rowing machines and accessories. Recommended on quality, never on commission.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="calendar" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Training Programs</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Structured plans for beginners, intermediates, and athletes targeting specific performance goals.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="apple" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Nutrition</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Fueling strategies for rowing training — what to eat, when to eat it, and why it matters for performance.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="heart" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Health Impacts</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Blood pressure, body composition, muscle activation — real case studies on what rowing does to your body.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="users" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Community</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Challenges, personal records, and shared experiences from the indoor rowing community.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Author -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-4xl px-6">
      <div class="flex flex-col items-center gap-4 text-center mb-10" data-reveal>
        <Badge variant="brand" pill>The Author</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Meet Tarquin Stapa
        </h2>
      </div>
      <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="1">
        <div class="flex flex-col md:flex-row gap-8 items-center md:items-start">
          <img
            src="/uploads/2023/12/Profile-Image-Tarquin-Stapa-1024x1024.webp"
            alt="Tarquin Stapa — Founder of Rowing With Watts"
            width="112"
            height="112"
            class="w-28 h-28 rounded-2xl object-cover object-top shrink-0"
            loading="eager"
          />
          <div class="flex-1 text-center md:text-left">
            <h3 class="text-xl font-bold text-foreground mb-1">Tarquin Stapa</h3>
            <p class="text-sm text-foreground-muted mb-1">Founder &amp; Chief Editor</p>
            <div class="flex items-center justify-center md:justify-start gap-1.5 text-xs text-foreground-muted mb-4">
              <Icon name="map-pin" size="sm" />
              New York, USA
            </div>
            <p class="text-foreground-muted leading-relaxed mb-4">
              Passionate indoor rowing enthusiast, performance data specialist, and founder of Rowing With Watts. After discovering rowing while recovering from a CrossFit knee injury, Tarquin dove deep into the science of indoor rowing and has been documenting every challenge, data point, and breakthrough since 2023.
            </p>
            <p class="text-foreground-muted leading-relaxed">
              Taking on rowing challenges and documenting the journey — so you have the data to make better decisions about your own training.
            </p>
            <div class="flex flex-wrap gap-2 mt-4 justify-center md:justify-start">
              <Badge variant="brand" size="sm">Indoor Rowing</Badge>
              <Badge variant="brand" size="sm">Watt-Based Training</Badge>
              <Badge variant="brand" size="sm">Performance Data</Badge>
              <Badge variant="brand" size="sm">New York</Badge>
            </div>
          </div>
        </div>
      </Card>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-2xl px-6 text-center" data-reveal>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Ready to start reading?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Explore our guides, case studies, and watt-based training resources.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/blog">
          Browse All Articles
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/contact">
          Get in Touch
        </Button>
      </div>
    </div>
  </section>
</PageLayout>
