---
import LandingLayout from '@/layouts/LandingLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';
import siteConfig from '@/config/site.config';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);
---

<LandingLayout
  title="Rowing With Watts — Power Your Performance"
  description="Honest guides, watt-based training data, and personal case studies for indoor rowing. No fluff — just results from a rower who trains in the numbers."
  image="/og-default.svg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero: water animation section -->
  <section
    class="rww-hero invert-section relative overflow-hidden"
    aria-label="Hero"
  >
    <!-- BG wave layers: sit BEHIND hero text (no z-index — paints below z:10 text)
         All wave divs are height:100% so they fill the hero regardless of its height.
         Crests are at 20-32% from SVG top → always near the heading text. -->
    <div class="rww-wave-bg" aria-hidden="true">

      <!-- Wave 1: Deepest current — crest at 20% of hero height (24s) -->
      <div class="rww-wave rww-wave-1" style="height:100%">
        <svg viewBox="0 0 2880 1000" xmlns="http://www.w3.org/2000/svg"
             preserveAspectRatio="none" style="display:block;width:100%;height:100%">
          <path
            d="M0,200 Q360,110 720,200 Q1080,290 1440,200 Q1800,110 2160,200 Q2520,290 2880,200 L2880,1000 L0,1000 Z"
            fill="rgba(18,12,50,0.90)"
          />
        </svg>
      </div>

      <!-- Wave 2: Mid-depth current — crest at 24% of hero height (18s) -->
      <div class="rww-wave rww-wave-2" style="height:100%">
        <svg viewBox="0 0 2880 1000" xmlns="http://www.w3.org/2000/svg"
             preserveAspectRatio="none" style="display:block;width:100%;height:100%">
          <path
            d="M0,240 Q360,162 720,240 Q1080,318 1440,240 Q1800,162 2160,240 Q2520,318 2880,240 L2880,1000 L0,1000 Z"
            fill="rgba(15,50,110,0.80)"
          />
        </svg>
      </div>

      <!-- Wave 3: Upper current — crest at 28% of hero height, clearly visible blue (13s) -->
      <div class="rww-wave rww-wave-3" style="height:100%">
        <svg viewBox="0 0 2880 1000" xmlns="http://www.w3.org/2000/svg"
             preserveAspectRatio="none" style="display:block;width:100%;height:100%">
          <path
            d="M0,280 Q360,210 720,280 Q1080,350 1440,280 Q1800,210 2160,280 Q2520,350 2880,280 L2880,1000 L0,1000 Z"
            fill="rgba(20,100,140,0.65)"
          />
        </svg>
      </div>

      <!-- Wave 4: Surface ripple — crest at 32%, brightest BG wave (9s) -->
      <div class="rww-wave rww-wave-4" style="height:100%">
        <svg viewBox="0 0 2880 1000" xmlns="http://www.w3.org/2000/svg"
             preserveAspectRatio="none" style="display:block;width:100%;height:100%">
          <path
            d="M0,320 Q360,258 720,320 Q1080,382 1440,320 Q1800,258 2160,320 Q2520,382 2880,320 L2880,1000 L0,1000 Z"
            fill="rgba(30,140,160,0.50)"
          />
        </svg>
      </div>

    </div><!-- /rww-wave-bg -->

    <!-- Hero content (z:10 — between BG and FG waves) -->
    <div class="relative z-10 mx-auto max-w-4xl px-6 pt-28 pb-32 md:pt-36 md:pb-40 text-center animate-hero-slide-up">

      <!-- Badge -->
      <div class="mb-6">
        <Badge variant="brand" pill pulse class="!bg-[rgba(40,180,160,0.2)] !text-[#5ce0d0] !border-[rgba(80,200,180,0.3)]">
          Real Data · Real Results
        </Badge>
      </div>

      <!-- Heading -->
      <h1 class="font-display text-4xl md:text-5xl font-black leading-tight tracking-tight text-white text-balance mb-6 rww-hero-text-glow">
        Power Your<br />
        <span class="rww-hero-accent">Performance</span>
      </h1>

      <!-- Subtext -->
      <p class="text-lg text-white/70 max-w-xl mx-auto mb-10 text-balance leading-relaxed">
        Watt-based training guides, personal case studies, and honest data from a real indoor rower. No fluff — just numbers that move the needle.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/blog" class="rounded-full hero-btn-brand !px-8">
          Read the Blog →
        </Button>
        <Button size="lg" variant="ghost" href="/about" class="rounded-full !text-white/80 !border !border-[rgba(80,200,180,0.25)] hover:!text-white hover:!bg-[rgba(50,180,160,0.12)]">
          About the Author
        </Button>
      </div>

    </div><!-- /hero content -->

    <!-- FG wave layers: sit IN FRONT of hero text (z:11 > text z:10) — semi-transparent
         These let the "Power Your Performance" heading breathe at the waterline. -->
    <div class="rww-wave-fg" aria-hidden="true">

      <!-- Wave 5: FG shimmer — passes in front of text, crest at 21% (21s) -->
      <div class="rww-wave rww-wave-5" style="height:100%">
        <svg viewBox="0 0 2880 1000" xmlns="http://www.w3.org/2000/svg"
             preserveAspectRatio="none" style="display:block;width:100%;height:100%">
          <path
            d="M0,210 Q360,138 720,210 Q1080,282 1440,210 Q1800,138 2160,210 Q2520,282 2880,210 L2880,1000 L0,1000 Z"
            fill="rgba(50,180,170,0.18)"
          />
        </svg>
      </div>

      <!-- Wave 6: FG gloss — very light, crest at 25% (16s) -->
      <div class="rww-wave rww-wave-6" style="height:100%">
        <svg viewBox="0 0 2880 1000" xmlns="http://www.w3.org/2000/svg"
             preserveAspectRatio="none" style="display:block;width:100%;height:100%">
          <path
            d="M0,250 Q360,185 720,250 Q1080,315 1440,250 Q1800,185 2160,250 Q2520,315 2880,250 L2880,1000 L0,1000 Z"
            fill="rgba(200,160,80,0.10)"
          />
        </svg>
      </div>

      <!-- Wave 7: Divider — fills with page background to create wave-cut boundary (19s) -->
      <div class="rww-wave rww-wave-7" style="height:180px">
        <svg viewBox="0 0 2880 180" xmlns="http://www.w3.org/2000/svg"
             preserveAspectRatio="none" style="display:block;width:100%;height:100%">
          <path
            class="rww-divider-path"
            d="M0,130 Q360,90 720,130 Q1080,170 1440,130 Q1800,90 2160,130 Q2520,170 2880,130 L2880,180 L0,180 Z"
          />
        </svg>
      </div>

    </div><!-- /rww-wave-fg -->
  </section>

  <!-- Stats Bar -->
  <section class="relative z-10 py-16 bg-background border-t border-border">
    <div class="mx-auto max-w-4xl px-6">
      <div class="grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-border" data-reveal>
        <div class="text-center py-6 md:py-0 md:px-8">
          <p class="text-brand-500 font-extrabold text-4xl leading-none tabular-nums">300,000+</p>
          <p class="text-xs text-foreground-subtle font-semibold uppercase tracking-widest mt-3">Meters Rowed In A Month</p>
        </div>
        <div class="text-center py-6 md:py-0 md:px-8">
          <p class="text-brand-500 font-extrabold text-4xl leading-none tabular-nums">1:27</p>
          <p class="text-xs text-foreground-subtle font-semibold uppercase tracking-widest mt-3">Best 500m Split</p>
        </div>
        <div class="text-center py-6 md:py-0 md:px-8">
          <p class="text-brand-500 font-extrabold text-4xl leading-none tabular-nums">10,000m</p>
          <p class="text-xs text-foreground-subtle font-semibold uppercase tracking-widest mt-3">40min 42sec</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Watts Section -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Why Watts?</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-extrabold text-foreground">
            Train smarter, not just harder
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          Pace is inconsistent. Heart rate lags. Watts are honest — they measure your actual power output in real time, making them the gold standard for indoor rowing training. Whether you're targeting a 2k PB, building aerobic base, or tracking progress month to month, watt-based training gives you objective data to make better decisions.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2" data-reveal data-reveal-delay="1">
        <!-- Power Output -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Power Output</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Watts tell you exactly how hard you're working — not an estimate, not a lag. Immediate, objective, honest.
              </p>
            </div>
          </div>
        </Card>

        <!-- Track Progress -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="trending-up" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Track Progress</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Compare your numbers week to week and month to month with data that doesn't lie. See real improvement.
              </p>
            </div>
          </div>
        </Card>

        <!-- Zone Training -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="activity" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Zone Training</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Target the right training zones with precision. Build your aerobic base or go anaerobic — on purpose.
              </p>
            </div>
          </div>
        </Card>

        <!-- Real Results -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="award" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Real Results</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Every guide on this site is backed by personal data from real rowing challenges. No theory without practice.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex items-end justify-between" data-reveal>
        <div class="flex flex-col gap-6">
          <Badge variant="brand" pill class="self-start">From the Blog</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-extrabold text-foreground">
            Latest Articles
          </h2>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors shrink-0">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-delay="1">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace('en/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            author={post.data.author}
            image={post.data.image}
            svgSlug={post.data.svgSlug}
          />
        ))}
      </div>

      <div class="text-center sm:hidden">
        <Button variant="outline" href="/blog">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-2xl px-6 text-center" data-reveal>
      <h2 class="font-display text-4xl font-extrabold text-foreground mb-4 text-balance">
        Ready to row with purpose?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Browse all guides and data-driven training advice.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/blog">
          Explore All Articles →
        </Button>
      </div>
    </div>
  </section>

</LandingLayout>
