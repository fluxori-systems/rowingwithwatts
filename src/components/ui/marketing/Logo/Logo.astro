---
/**
 * Logo Component
 *
 * Renders the Rowing With Watts SVG logo.
 * - Dark backgrounds (header/footer): logo.svg (white text, transparent bg)
 * - Light backgrounds: logo-dark.svg (dark text, transparent bg)
 * - Logomark/icon variant: logo-icon.svg (square icon)
 * - When `letter` prop is provided: renders author-avatar monogram badge
 *   (kept for BlogCard bylines)
 */
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  forceDark?: boolean;
  variant?: 'logomark' | 'full';
  class?: string;
  letter?: string;
}

const { size = 'md', forceDark = false, variant = 'full', class: className, letter } = Astro.props;

const heightMap: Record<string, string> = {
  sm: 'h-6', md: 'h-8', lg: 'h-10', xl: 'h-14', '2xl': 'h-20',
};
const h = heightMap[size] ?? 'h-8';

// Monogram badge sizing (for author avatars)
const monogramSize: Record<string, string> = {
  sm: 'w-5 h-5 text-[14px] rounded-[4px]',
  md: 'w-6 h-6 text-[16px] rounded-[5px]',
  lg: 'w-8 h-8 text-[22px] rounded-[6px]',
  xl: 'w-12 h-12 text-[34px] rounded-[8px]',
  '2xl': 'w-24 h-24 text-[68px] rounded-[14px]',
};
const monogramClasses = monogramSize[size] ?? monogramSize.md;

const isLogomark = variant === 'logomark';
---

{letter ? (
  <span
    class={cn(
      'inline-flex items-center justify-center shrink-0 bg-brand-500 text-white font-display font-bold leading-none select-none',
      monogramClasses,
      className
    )}
    aria-label={siteConfig.branding.logo.alt}
    role="img"
  >
    {letter}
  </span>
) : isLogomark ? (
  <img
    src="/logo-icon.svg"
    alt={siteConfig.branding.logo.alt}
    class={cn(h, 'w-auto', className)}
    loading="eager"
    decoding="async"
  />
) : (
  <>
    {/* Dark mode: white-text logo — shown when .dark class is on <html> */}
    <img
      src="/logo.svg"
      alt={siteConfig.branding.logo.alt}
      class={cn(h, 'w-auto hidden dark:block', forceDark ? '!block' : '', className)}
      loading="eager"
      decoding="async"
    />
    {/* Light mode: dark-text logo — shown when no .dark class on <html> */}
    <img
      src="/logo-dark.svg"
      alt={siteConfig.branding.logo.alt}
      class={cn(h, 'w-auto block dark:hidden', forceDark ? '!hidden' : '', className)}
      loading="eager"
      decoding="async"
    />
  </>
)}
